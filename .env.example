PORT=3000

# Portal Único Siscomex — Chave de Acesso (gerada em
# https://docs.portalunico.siscomex.gov.br/pages/chaves-acesso/)
PUCOMEX_AUTH_BASE_URL=https://portalunico.siscomex.gov.br/portal
PUCOMEX_API_BASE_URL=https://portalunico.siscomex.gov.br
PUCOMEX_CLIENT_ID=
PUCOMEX_CLIENT_SECRET=
# Perfil de atuação (ver tabela "Perfis de Acesso" na doc de Autenticação).
# IMPEXP confirmado como o Role-Type correto para esta chave de acesso.
PUCOMEX_ROLE_TYPE=IMPEXP

# "Chave secreta" preenchida na inscrição do webhook no Portal Único (tela
# "Inclusão de Assinatura de Eventos"). O Portal Único envia essa mesma
# chave de volta no header "Secret" de cada chamada de notificação.
PUCOMEX_WEBHOOK_SECRET=

# IDs de evento a processar (separados por vírgula). Vazio = processa qualquer evento reconhecido.
# dimp-registro-import = resultado da solicitação de registro de uma DUIMP.
# É o gatilho: dispara quando a DUIMP é registrada (já inscrito no Portal Único).
PUCOMEX_WATCHED_EVENT_IDS=dimp-registro-import

# CPFs (com ou sem pontuação, tanto faz) dos despachantes cujas DUIMPs devem
# disparar a automação — separados por vírgula. Compara com o campo
# responsavelRegistroNumero da DUIMP. Necessário porque nem toda DUIMP
# visível no Portal Único é despachada por você (alguns clientes você só
# visualiza, quem despacha é outra pessoa). Vazio = processa qualquer
# declarante (não recomendado em produção).
PUCOMEX_CPFS_RESPONSAVEIS_AUTORIZADOS=

# Códigos de recinto/URF de despacho (campo urfDespacho.codigo da DUIMP) para
# os quais a automação deve disparar — separados por vírgula. O e-mail de
# armazenagem só faz sentido para cargas no terminal do RioGaleão. Vazio =
# processa qualquer recinto (não recomendado em produção).
# 0717700 = AEROPORTO INTERNACIONAL GALEÃO (RJ)
PUCOMEX_CODIGOS_RECINTO_AUTORIZADOS=0717700

# Casos em que a fatura de armazenagem deve sair contra um CNPJ diferente do
# CNPJ do importador na DUIMP. Formato: "CNPJ_cliente:CNPJ_pagador" (só
# dígitos ou com pontuação, tanto faz), pares separados por ";". Vazio =
# nenhum cliente com CNPJ pagador diferente.
# Exemplo (cliente PERENCO): CNPJ do importador 09.309.027/0003-05, mas a
# fatura deve sair contra o CNPJ 09.309.027/0004-88.
PUCOMEX_CNPJ_PAGADOR_OVERRIDES=09309027000305:09309027000488

# Provedor de envio: "graph" (produção, Microsoft 365) ou "smtp" (teste local
# com conta pessoal, ex: Gmail — ver instruções abaixo). Padrão: graph.
MAIL_PROVIDER=graph

# Microsoft Graph — app registration (client credentials) com permissão Mail.Send
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# SMTP genérico — só usado quando MAIL_PROVIDER=smtp. Para testar com Gmail:
# 1. Ative a verificação em duas etapas na conta Google.
# 2. Gere uma "senha de app" em https://myaccount.google.com/apppasswords
# 3. SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=seu-email@gmail.com,
#    SMTP_PASS=<a senha de app gerada, sem espaços>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Se der erro "self-signed certificate in certificate chain" ao conectar
# (comum em rede corporativa com antivírus/proxy que intercepta TLS), deixe
# false só para teste local — nunca em produção.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Caixa de e-mail que envia. Com MAIL_PROVIDER=graph, precisa de licença no
# Microsoft 365. Com MAIL_PROVIDER=smtp, pode deixar em branco (usa SMTP_USER).
MAIL_FROM=
MAIL_TO_TARIFACAO=
MAIL_CC=

# true = loga o e-mail em vez de enviar de verdade
DRY_RUN=false
