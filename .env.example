PORT=3000

# Portal Único Siscomex — Chave de Acesso (gerada em
# https://docs.portalunico.siscomex.gov.br/pages/chaves-acesso/)
PUCOMEX_AUTH_BASE_URL=https://portalunico.siscomex.gov.br/portal
PUCOMEX_API_BASE_URL=https://portalunico.siscomex.gov.br
PUCOMEX_CLIENT_ID=
PUCOMEX_CLIENT_SECRET=
# Perfil de atuação (ver tabela "Perfis de Acesso" na doc de Autenticação).
# IMPEXP confirmado como o Role-Type correto para esta chave de acesso.
PUCOMEX_ROLE_TYPE=IMPEXP

# Segredo combinado na inscrição do webhook, usado para validar chamadas recebidas
PUCOMEX_WEBHOOK_SECRET=

# IDs de evento a processar (separados por vírgula). Vazio = processa qualquer evento reconhecido.
# dimp-registro-import = resultado da solicitação de registro de uma DUIMP.
# É o gatilho: dispara quando a DUIMP é registrada (já inscrito no Portal Único).
PUCOMEX_WATCHED_EVENT_IDS=dimp-registro-import

# Provedor de envio: "graph" (produção, Microsoft 365) ou "smtp" (teste local
# com conta pessoal, ex: Gmail — ver instruções abaixo). Padrão: graph.
MAIL_PROVIDER=graph

# Microsoft Graph — app registration (client credentials) com permissão Mail.Send
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# SMTP genérico — só usado quando MAIL_PROVIDER=smtp. Para testar com Gmail:
# 1. Ative a verificação em duas etapas na conta Google.
# 2. Gere uma "senha de app" em https://myaccount.google.com/apppasswords
# 3. SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=seu-email@gmail.com,
#    SMTP_PASS=<a senha de app gerada, sem espaços>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Caixa de e-mail que envia. Com MAIL_PROVIDER=graph, precisa de licença no
# Microsoft 365. Com MAIL_PROVIDER=smtp, pode deixar em branco (usa SMTP_USER).
MAIL_FROM=
MAIL_TO_TARIFACAO=
MAIL_CC=

# true = loga o e-mail em vez de enviar de verdade
DRY_RUN=false
